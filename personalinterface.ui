         <widget class="QGroupBox" name="groupBox">
          <property name="styleSheet">
           <string notr="true">/* GroupBox Styling */
QGroupBox {
    background-color: #FBFCFC; /* Very light background for distinction */
    border: 1px solid #D5DBDB;
    border-radius: 6px;
    padding: 10px;
    margin-top: 20px; /* Space for the title */
    font-weight: bold;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 8px 0 8px;
    margin-left: 10px;
    background-color: #FBFCFC; /* Match groupbox background */
    color: #2980B9; /* Professional blue for titles */
    font-size: 11pt;
}</string>
