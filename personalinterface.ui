            <string notr="true">/* LineEdit and TextEdit Styling */
QLineEdit, QTextEdit {
    background-color: #FFFFFF;
    border: 1px solid #BDC3C7; /* Softer border color */
    border-radius: 4px;
    padding: 1px;
    color: #2C3E50;
    selection-background-color: #AED6F1; /* Light blue selection */
    selection-color: #1A5276;
}

QLineEdit:focus, QTextEdit:focus {
    border: 1px solid #3498DB; /* Highlight border on focus - a clear, friendly blue */
    /* box-shadow: 0 0 3px #3498DB;  Unfortunately, box-shadow is not well supported in QSS */
}

QLineEdit:read-only, QTextEdit:read-only {
    background-color: #ECF0F1; /* Slightly different background for read-only fields */
    color: #7F8C8D;
}</string>
