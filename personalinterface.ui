    border-radius: 4px;
    padding: 5px 12px;
    font-weight: 500;
}

QPushButton:hover {
    background-color: #e0d4f8;
    border-color: #8c6dc9;
}

QPushButton:pressed {
    background-color: #c9b8eb;
}

QPushButton:disabled {
    background-color: #e6e0f0;
    color: #a99bc0;
}</string>
