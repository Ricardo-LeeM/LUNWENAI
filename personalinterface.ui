      <item row="2" column="0">
       <layout class="QHBoxLayout" name="horizontalLayout">
        <item>
         <widget class="QPushButton" name="btnToExcel">
          <property name="maximumSize">
           <size>
            <width>1111</width>
            <height>1111</height>
           </size>
          </property>
          <property name="styleSheet">
           <string notr="true">/* PushButton Styling */
QPushButton {
    background-color: #3498DB; /* Primary action blue */
    color: white;
    border: none;
    padding: 1px 2px;
    border-radius: 4px;
    font-size: 10pt;
    font-weight: bold;
    min-width: 80px; /* Ensure buttons have a decent minimum width */
}

QPushButton:hover {
    background-color: #2980B9; /* Darker shade on hover */
}

QPushButton:pressed {
    background-color: #1F618D; /* Even darker when pressed */
}

QPushButton:disabled {
    background-color: #AAB7B8;
    color: #E5E7E9;
}

/* Specific button types (e.g., secondary or caution) could be styled with object names */
QPushButton#secondaryButton {
    background-color: #EAECEE;
    color: #34495E;
    border: 1px solid #BDC3C7;
}

QPushButton#secondaryButton:hover {
    background-color: #D5D8DC;
}

QPushButton#secondaryButton:pressed {
    background-color: #ABB2B9;
}
</string>
          </property>
          <property name="text">
           <string>导出表格</string>
          </property>
         </widget>
        </item>
