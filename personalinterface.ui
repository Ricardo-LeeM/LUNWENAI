    border: none;
    border-radius: 20px; /* 大圆角看起来更现代 */
    padding: 10px 20px;
    font-size: 40px;
    font-weight: bold;
    /* Qt 里模拟一点阴影感 */
    border-bottom: 3px solid #047857; 
}
QPushButton:hover {
    background-color: #059669;
    border-bottom: 3px solid #064E3B;
}
QPushButton:pressed {
    background-color: #047857;
    border-bottom: 1px solid #047857;
