         <string notr="true">QFrame { /* Example: if you named your sidebar QFrame &quot;leftSidebarFrame&quot; */
    background-color: #2C3E50; /* A deep, professional blue-gray */
    border-right: 1px solid #34495E;
}

/* ToolButton in Sidebar (Navigation) */
QFrame QToolButton {
    background-color: transparent;
    color: #ECF0F1; /* Light text color for contrast against dark sidebar */
    border: none;
    padding: 12px 15px; /* Ample padding */
    text-align: left;
    font-size: 10pt;
    font-weight: bold;
    border-radius: 4px; /* Slightly rounded corners */
    margin: 5px 10px;
}

QFrame QToolButton:hover {
    background-color: #34495E; /* Darker shade on hover */
    color: #FFFFFF;
}

QFrame QToolButton:checked,
QFrame QToolButton:pressed {
    background-color: #1ABC9C; /* A pleasant teal accent for selected/pressed */
    color: #FFFFFF;
}

/* ComboBox in Sidebar (e.g., &quot;个人中心&quot;) */
QFrame QComboBox {
    background-color: #34495E;
    color: #ECF0F1;
    border: 1px solid #4A6178;
    padding: 8px 10px;
    border-radius: 4px;
    margin: 10px;
    font-weight: bold;
}

QFrameFrame QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 20px;
    border-left-width: 1px;
    border-left-color: #4A6178;
    border-left-style: solid;
    border-top-right-radius: 3px;
    border-bottom-right-radius: 3px;
}

QFrameQComboBox::down-arrow {
    image: url(:/qt-project.org/styles/commonstyle/images/downarrrow-16.png); /* Default Qt arrow, consider a custom one */
    width: 12px;
    height: 12px;
}
QFrame QComboBox::down-arrow:on {
    image: url(:/qt-project.org/styles/commonstyle/images/uparrrow-16.png);
}

QFrameQComboBox QAbstractItemView { /* Dropdown list style */
    background-color: #34495E;
    color: #ECF0F1;
    border: 1px solid #4A6178;
    selection-background-color: #1ABC9C;
    padding: 5px;
}
</string>
