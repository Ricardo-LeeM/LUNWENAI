        <property name="styleSheet">
         <string notr="true">QTableWidget {
    background-color: #2c3e50; /* 深蓝灰色背景 */
    border: 1px solid #34495e;
    color: #ecf0f1; /* 亮灰色文字 */
    gridline-color: #34495e; /* 网格线颜色 */
    alternate-background-color: #34495e; /* 隔行变色 */
}

/* 表头样式 */
QTableWidget QHeaderView::section {
    background-color: #34495e;
    color: #ecf0f1;
    padding: 8px;
    border: none;
    border-bottom: 2px solid #3498db; /* 蓝色底边框作为点缀 */
    font-weight: bold;
    text-transform: uppercase; /* 字母大写，更显专业 */
}

/* 单元格样式 */
QTableWidget::item {
    border-bottom: 1px solid #34495e;
    padding: 5px;
}

/* 选中单元格样式 */
QTableWidget::item:selected {
    background-color: #3498db; /* 选中时使用主题蓝色 */
    color: white;
}

/* 表格专属滚动条 */
QTableWidget QScrollBar:vertical {
    border: none;
    background: transparent;
    width: 10px;
    margin: 12px 0 12px 0;
}

QTableWidget QScrollBar::handle:vertical {
    background-color: #3498db;
    min-height: 25px;
    border-radius: 5px;
}

QTableWidget QScrollBar::handle:vertical:hover {
    background-color: #5dade2;
}

QTableWidget QScrollBar::add-line:vertical, QTableWidget#darkKnightTable QScrollBar::sub-line:vertical {
    height: 0px;
}

QTableWidget QScrollBar::add-page:vertical, QTableWidget#darkKnightTable QScrollBar::sub-page:vertical {
    background: none;
}

QTableWidget QScrollBar:horizontal {
    border: none;
    background: transparent;
    height: 10px;
    margin: 0 12px 0 12px;
}

QTableWidget QScrollBar::handle:horizontal {
    background-color: #3498db;
    min-width: 25px;
    border-radius: 5px;
}

QTableWidget QScrollBar::handle:horizontal:hover {
    background-color: #5dade2;
}

QTableWidget QScrollBar::add-line:horizontal, QTableWidget#darkKnightTable QScrollBar::sub-line:horizontal {
    width: 0px;
}

QTableWidget QScrollBar::add-page:horizontal, QTableWidget#darkKnightTable QScrollBar::sub-page:horizontal {
    background: none;
}
</string>
