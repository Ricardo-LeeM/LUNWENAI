   <item row="1" column="0">
    <widget class="QTabWidget" name="tabWidget">
     <property name="styleSheet">
      <string notr="true">QTabWidget::pane {
    border: 1px solid #dcdde1;
    border-top: none; /* 顶部边框由TabBar处理 */
    background-color: white;
}

/* Tab 栏 */
QTabBar::tab {
    background-color: #e9ecef;
    color: #8c8c8c;
    border: 1px solid #dcdde1;
    border-bottom: none; /* 底部边框在选中时处理 */
    padding: 8px 25px;
    margin-right: 2px;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
}

/* Tab 鼠标悬浮 */
QTabBar::tab:hover {
    background-color: #f0f2f5;
    color: #3498db;
}

/* Tab 选中状态 */
QTabBar::tab:selected {
    background-color: white; /* 与Tab页内容区融为一体 */
    color: #3498db;
    font-weight: bold;
    border-color: #dcdde1;
    border-bottom-color: white; /* 关键：隐藏底部边框，实现连接效果 */
}</string>
     </property>
