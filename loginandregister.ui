         <property name="styleSheet">
          <string notr="true">QLineEdit {
    background-color: white; /* 输入框背景颜色 */
    border: 1px solid #cccccc; /* 边框样式 */
    border-radius: 3px; /* 圆角 */
    padding: 5px; /* 内边距 */
    font-size: 14px; /* 字体大小 */
}

QLineEdit:focus {
    border: 1px solid #4CAF50; /* 获取焦点时的边框颜色 */
    background-color: #f5f5f5; /* 获取焦点时的背景颜色 */
}</string>
         </property>
        </widget>
       </item>
      </layout>
