  <property name="styleSheet">
   <string notr="true">/* 蓝色边框圆角按钮 - 自适应尺寸 */
QPushButton {
    /* 基础样式 */
    background-color: #ffffff;
    color: #000000;
    border: 2px solid #1a5fc4;
    border-radius: 8px;
    padding: 1px 1px;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
    font-size: 14px;
    font-weight: 600;
    margin: 4px;
}

/* 悬停状态 */
QPushButton:hover {
    background-color: #f0f7ff;
    border: 2px solid #0f4aa0;
}

/* 按下状态 */
QPushButton:pressed {
    background-color: #d0e1ff;
    border: 2px solid #09367c;
}

/* 焦点状态 */
QPushButton:focus {
    border: 2px solid #4a9dff;
    outline: none;
}

/* 禁用状态 */
QPushButton:disabled {
    background-color: #f8f9fa;
    color: #a0a0a0;
    border: 2px solid #e0e0e0;
}</string>
  </property>
  <layout class="QGridLayout" name="gridLayout">
   <item row="0" column="0">
    <widget class="QLabel" name="label">
     <property name="styleSheet">
      <string notr="true">/* 多彩渐变边框，内部白色背景 */
QLabel {
    background-color: white;
    color: #333333;
    font-size: 15px;
    font-weight: bold;
    border: 5px solid;
    border-image: linear-gradient(to right, #ff3366, #ff9933, #ffcc00, #33cc33, #3399ff, #9966ff) 1;
    border-radius: 15px;
    padding: 15px;
    margin: 5px;
    qproperty-alignment: AlignCenter;
}</string>
     </property>
     <property name="text">
