}</string>
        </property>
        <property name="text">
         <string>删除选中行</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QPushButton" name="calculateButton">
        <property name="styleSheet">
         <string notr="true">QPushButton#calculateButton {
    background-color: #3498db; /* 主题蓝 */
    font-weight: bold;
}
QPushButton#calculateButton:hover {
    background-color: #5dade2;
}
QPushButton#calculateButton:pressed {
    background-color: #2980b9;
}
</string>
        </property>
        <property name="text">
         <string>计算工资</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QPushButton" name="saveButton">
        <property name="styleSheet">
         <string notr="true">QPushButton#saveButton {
    background-color: #f39c12; /* 醒目的橙色，表示“确认/保存” */
    font-weight: bold;
    color: white;
}
QPushButton#saveButton:hover {
    background-color: #f5b041;
}
QPushButton#saveButton:pressed {
    background-color: #d68910;
}</string>
        </property>
        <property name="text">
         <string>保存更改</string>
        </property>
       </widget>
