}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top center; /* 标题位置 */
    padding: 0 10px; /* 标题内边距 */
    background-color: #f5f5f5; /* 浅灰色标题背景 */
    color: #333333; /* 深灰色标题文字 */
    font-weight: bold; /* 标题加粗 */
}</string>
